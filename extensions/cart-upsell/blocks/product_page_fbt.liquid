{% assign active_offers = shop.metafields.beta_upsell.active_offers.value %}
{% assign app_settings = shop.metafields.beta_upsell.settings.value %}
{% assign target_offer = null %}

{% if active_offers %}
  {% for offer in active_offers %}
    {% assign target_offer = offer %}
    {% break %}
  {% endfor %}
{% endif %}

{% assign widget_title = app_settings.widgetTitle | default: block.settings.heading | default: 'Frequently Bought Together' %}
{% assign btn_color = app_settings.primaryColor | default: block.settings.button_color %}

{% if target_offer != null and target_offer.handle != blank and product.id != blank %}
  {% assign upsell_product = all_products[target_offer.handle] %}
  
  {% if upsell_product != blank and upsell_product.id != product.id %}
    <div class="beta-fbt-widget" style="padding: 20px; border: 1px solid {{ block.settings.border_color }}; border-radius: 8px; background: {{ block.settings.bg_color }}; margin: 20px 0;">
      <h3 style="margin: 0 0 15px; color: {{ block.settings.text_color }}; font-size: 16px; font-weight: 600;">{{ widget_title }}</h3>
      
      <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
        <!-- Main Product Image -->
        <div style="position: relative;">
          <img src="{{ product.featured_image | img_url: '100x100', crop: 'center' }}" alt="{{ product.title }}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 6px; border: 1px solid #eee;">
        </div>
        
        <!-- Plus Sign -->
        <div style="font-size: 20px; font-weight: bold; color: #888;">+</div>
        
        <!-- Upsell Product Image -->
        <div style="position: relative;">
          <img src="{{ upsell_product.featured_image | img_url: '100x100', crop: 'center' }}" alt="{{ upsell_product.title }}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 6px; border: 1px solid #eee;">
        </div>
      </div>
      
      <div style="margin-bottom: 20px;">
        <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; margin-bottom: 10px;">
          <input type="checkbox" checked disabled style="margin-top: 4px;">
          <div>
            <span style="font-weight: 600; color: {{ block.settings.text_color }};">This item:</span> {{ product.title }}
            <div style="font-weight: bold; margin-top: 2px;">{{ product.price | money }}</div>
          </div>
        </label>
        
        <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer;">
          <input type="checkbox" id="beta_fbt_checkbox" checked style="margin-top: 4px;">
          <div>
            <span style="color: {{ block.settings.text_color }};">{{ upsell_product.title }}</span>
            <div style="display: flex; gap: 8px; margin-top: 2px;">
              {% if target_offer.discountType == 'percentage' %}
                {% assign discount_decimal = target_offer.discountValue | divided_by: 100.0 %}
                {% assign discount_amount = upsell_product.price | times: discount_decimal %}
                {% assign final_upsell_price = upsell_product.price | minus: discount_amount %}
              {% else %}
                {% assign discount_cents = target_offer.discountValue | times: 100 %}
                {% assign final_upsell_price = upsell_product.price | minus: discount_cents %}
              {% endif %}
              
              <span style="font-weight: bold; color: {{ block.settings.text_color }};" id="beta_fbt_upsell_price" data-price="{{ final_upsell_price }}">{{ final_upsell_price | money }}</span>
              <span style="text-decoration: line-through; color: #888;">{{ upsell_product.price | money }}</span>
            </div>
          </div>
        </label>
      </div>
      
      <div style="border-top: 1px solid #eee; padding-top: 15px; display: flex; flex-direction: column; gap: 12px;">
        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 16px;">
          <span style="color: {{ block.settings.text_color }};">Total price:</span>
          <span style="font-weight: bold; color: {{ block.settings.text_color }};" id="beta_fbt_total_price" data-main-price="{{ product.price }}">{{ product.price | plus: final_upsell_price | money }}</span>
        </div>
        
        <button id="beta_fbt_add_btn" style="width: 100%; padding: 12px; background: {{ btn_color }}; color: {{ block.settings.button_text_color }}; border: none; border-radius: 6px; font-weight: bold; font-size: 15px; cursor: pointer;">
          Add Bundle to Cart
        </button>
      </div>
    </div>

    <script>
      (function() {
        // Track impression
        fetch('/apps/beta-upsell/api/events', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            shop: Shopify.shop,
            offerId: '{{ target_offer.id }}',
            eventType: 'shown'
          })
        }).catch(e => console.error(e));

        var checkbox = document.getElementById('beta_fbt_checkbox');
        var totalPriceEl = document.getElementById('beta_fbt_total_price');
        var addBtn = document.getElementById('beta_fbt_add_btn');
        var mainPrice = parseInt(totalPriceEl.getAttribute('data-main-price'), 10);
        var upsellPrice = parseInt(document.getElementById('beta_fbt_upsell_price').getAttribute('data-price'), 10);
        var currencySymbol = totalPriceEl.innerText.replace(/[0-9.,]/g, '').trim() || '$'; // Basic currency fallback
        
        // Simple money formatter for total update
        function formatMoney(cents) {
          return currencySymbol + (cents / 100).toFixed(2);
        }

        checkbox.addEventListener('change', function() {
          if (this.checked) {
            totalPriceEl.innerText = formatMoney(mainPrice + upsellPrice);
            addBtn.innerText = 'Add Bundle to Cart';
          } else {
            totalPriceEl.innerText = formatMoney(mainPrice);
            addBtn.innerText = 'Add Item to Cart';
          }
        });

        addBtn.addEventListener('click', function() {
          addBtn.innerText = 'Adding...';
          addBtn.disabled = true;

          var items = [{
            id: {{ product.variants.first.id }},
            quantity: 1
          }];

          if (checkbox.checked) {
            items.push({
              id: {{ upsell_product.variants.first.id }},
              quantity: 1,
              properties: {
                '_upsell_offer_id': '{{ target_offer.id }}'
              }
            });
            
            // Track accepted
            fetch('/apps/beta-upsell/api/events', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                shop: Shopify.shop,
                offerId: '{{ target_offer.id }}',
                eventType: 'accepted',
                upsellRevenue: upsellPrice / 100
              })
            }).catch(e => console.error(e));
          } else {
             // Track declined
             fetch('/apps/beta-upsell/api/events', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                shop: Shopify.shop,
                offerId: '{{ target_offer.id }}',
                eventType: 'declined'
              })
            }).catch(e => console.error(e));
          }

          fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: items })
          })
          .then(response => {
            if (response.ok) {
              window.location.href = '/cart';
            } else {
              addBtn.innerText = 'Error adding to cart';
            }
          })
          .catch((error) => {
            console.error('Error:', error);
            addBtn.innerText = 'Error';
          });
        });
      })();
    </script>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "FBT Upsell Block",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Widget Heading",
      "default": "Frequently Bought Together"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#eaeaea"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
