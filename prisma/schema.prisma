// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id           String   @id @default(uuid())
  shopDomain   String   @unique
  accessToken  String?
  plan         String   @default("free")
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  offers       Offer[]
  offerEvents  OfferEvent[]
  analytics    AnalyticsDaily[]
}

model Offer {
  id                String   @id @default(uuid())
  storeId           String
  name              String
  type              String   // post_purchase, checkout, cart, product_page
  triggerProductIds String[] // Array of product IDs that trigger the offer
  upsellProductId   String
  conditions        Json     @default("{}") // cart value, customer tag, etc.
  discountType      String   // percentage, fixed_amount
  discountValue     Float
  isActive          Boolean  @default(true)
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store             Store    @relation(fields: [storeId], references: [id])
  offerEvents       OfferEvent[]
  analytics         AnalyticsDaily[]
}

model OfferEvent {
  id                   String   @id @default(uuid())
  storeId              String
  offerId              String
  orderId              String?
  customerId           String?
  eventType            String   // shown, accepted, declined
  upsellRevenue        Float    @default(0.0)
  originalOrderValue   Float    @default(0.0)
  sessionData          Json     @default("{}")
  createdAt            DateTime @default(now())

  store                Store    @relation(fields: [storeId], references: [id])
  offer                Offer    @relation(fields: [offerId], references: [id])
}

model AnalyticsDaily {
  id                   String   @id @default(uuid())
  storeId              String
  offerId              String
  date                 DateTime @db.Date
  impressions          Int      @default(0)
  accepts              Int      @default(0)
  declines             Int      @default(0)
  totalUpsellRevenue   Float    @default(0.0)
  avgOrderValueLift    Float    @default(0.0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  store                Store    @relation(fields: [storeId], references: [id])
  offer                Offer    @relation(fields: [offerId], references: [id])

  @@unique([storeId, offerId, date])
}
